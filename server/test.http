### Login
POST http://localhost:4000/auth/login
Content-Type: application/json

{
  "email": "test@mail.com",
  "password": "12345678"
}
###
> {% 
client.global.set("token", response.body.token);
%}

### Register
POST http://localhost:4000/auth/register
Content-Type: application/json

{
    "email": "test3@mail.com",
    "password": "12345678",
    "display_name": "test"
}

